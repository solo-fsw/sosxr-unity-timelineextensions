{
  "name": "com.sosxr.extendingtimeline",
  "version": "2.1.0",
  "displayName": "Extending Timeline",
  "description": "A collection of scripts that extend the Unity Timeline.",
  "unity": "2021.3",
  "dependencies": {
    "com.unity.timeline": "1.8.8"
  },
  "keywords": [
    "timeline",
    "animation",
    "rigging"
  ],
  "samples": [
    {
      "displayName": "Samples",
      "description": "Contains samples of this package",
      "path": "Samples~/Samples"
    },
    {
      "displayName": "Animation Rigging",
      "description": "Contains Animation Rigging Timeline, since it requires Animation Rigging to work",
      "path": "Samples~/AnimationRigging"
    },
    {
      "displayName": "TextMesh Pro",
      "description": "Contains TextMesh Pro Timeline, since it requires TextMesh Pro to work",
      "path": "Samples~/TextMeshPro"
    },
    {
      "displayName": "Post Processing",
      "description": "Contains Post Processing Timeline, since it requires Post Processing to work",
      "path": "Samples~/PostProcessing"
    },
    {
      "displayName": "Design Patterns",
      "description": "Contains Design Pattern timeline components, since it requires SeaShark to work",
      "path": "Samples~/DesignPatterns"
    }
  ],
  "author": {
    "name": "SOSXR",
    "email": "sosxr@fsw.leidenuniv.nl",
    "url": "https://researchwiki.solo.universiteitleiden.nl/xwiki/bin/view/Main/"
  },
  "changelogUrl": "https://github.com/solo-fsw/sosxr-unity-timelineextensions/blob/main/CHANGELOG.md"
}